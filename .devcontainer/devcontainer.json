{
    "name": "PyPSA-USA",

    // Build from local Dockerfile; context is repo root so COPY can reach workflow/envs/
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },

    // Run as "vscode" user (uid 1000), provided by the devcontainer base image
    "remoteUser": "vscode",

    // Runs once after the container is first created (not on every start)
    "postCreateCommand": "bash .devcontainer/postCreate.sh",

    "customizations": {
        "vscode": {
            "settings": {
                // Python interpreter is the one inside the micromamba-managed pypsa-usa env
                "python.defaultInterpreterPath": "/opt/conda/envs/pypsa-usa/bin/python",

                // Ruff for formatting and linting (matches ruff config in pyproject.toml)
                "editor.formatOnSave": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "ruff.path": ["/opt/conda/envs/pypsa-usa/bin/ruff"],

                // Point Snakemake extension to the env's snakemake binary
                "snakemake.executable": "/opt/conda/envs/pypsa-usa/bin/snakemake",

                "editor.rulers": [120]
            },
            "extensions": [
                // Python core
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.mypy-type-checker",

                // Linting/formatting (project uses ruff — see pyproject.toml)
                "charliermarsh.ruff",

                // Snakemake workflow files
                "snakemake.snakemake-lang",

                // Data/config formats
                "redhat.vscode-yaml",
                "ms-toolsai.jupyter",

                // Git
                "eamodio.gitlens"
            ]
        }
    },

    // Forward Dask dashboard port if needed during development
    "forwardPorts": []
}
